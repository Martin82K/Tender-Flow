+          id,
+          %I,
+          subcontractor_id,
+          company_name,
+          contact_person,
+          email,
+          phone,
+          price,
+          price_display,
+          price_history,
+          notes,
+          status,
+          update_date,
+          selection_round,
+          contracted
+        ) VALUES (
