+    v_new_project_id,
+    p.name,
+    p.location,
+    'realization',
+    p.owner_id,
+    p.organization_id,
+    COALESCE(p.is_demo, false),
+    p.investor,
+    p.technical_supervisor,
+    p.finish_date,
+    p.site_manager,
+    p.construction_manager,
+    p.construction_technician,
+    p.planned_cost
+  FROM public.projects p
