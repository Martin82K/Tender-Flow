+        v_source_bid.contact_person,
+        v_source_bid.email,
+        v_source_bid.phone,
+        v_effective_price_history;
+    END LOOP;
+  END LOOP;
+
+  INSERT INTO public.project_shares (project_id, user_id, permission)
