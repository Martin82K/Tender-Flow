{
    "rewrites": [
        {
            "source": "/api/updates/win/latest.yml",
            "destination": "/api/updates/win/latest"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}
